properties:
  note.Name:
    displayName: Name
  note.Class:
    displayName: Class
  note.Strength:
    displayName: Strength
  note.Intelligence:
    displayName: Intelligence
  note.Agility:
    displayName: Agility
views:
  - type: parallel-chart
    name: Character stats (parallel)
    filters:
      and:
        - note.Class != null
    xProp: note.Strength, note.Intelligence, note.Agility
    seriesProp: note.Class
