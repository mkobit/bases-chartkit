properties:
  note.Continent:
    displayName: Continent
  note.GDP:
    displayName: GDP
  note.LifeExpectancy:
    displayName: Life Expectancy
views:
  - type: scatter-chart
    name: GDP vs life expectancy
    xAxisProp: note.GDP
    yAxisProp: note.LifeExpectancy
    seriesProp: note.Continent
    showLegend: true
    filters:
      and:
        - file.folder == "scatter/notes"
