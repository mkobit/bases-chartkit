properties:
  note.Department:
    displayName: Department
  note.Spend:
    displayName: Spend
views:
  - type: radial-bar-chart
    name: Department spend (radial bar)
    xAxisProp: note.Department
    yAxisProp: note.Spend
    showLegend: true
    filters:
      and:
        - file.folder == "radial-bar/notes"
