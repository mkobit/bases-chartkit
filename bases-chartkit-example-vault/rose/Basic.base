properties:
  note.Department:
    displayName: Department
  note.Spend:
    displayName: Spend
views:
  - type: rose-chart
    name: Department spend (rose)
    xAxisProp: note.Department
    yAxisProp: note.Spend
    showLegend: true
    legendPosition: "right"
    filters:
      and:
        - file.folder == "rose/notes"
