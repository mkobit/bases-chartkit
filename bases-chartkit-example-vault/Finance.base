properties:
  note.Date:
    displayName: Date
  note.Open:
    displayName: Open price
  note.Close:
    displayName: Close price
  note.High:
    displayName: High price
  note.Low:
    displayName: Low price
views:
  - type: candlestick-chart
    name: AAPL stock analysis
    xAxisProp: note.Date
    openProp: note.Open
    closeProp: note.Close
    highProp: note.High
    lowProp: note.Low
    showLegend: true
    filters:
      and:
        - note.Symbol == "AAPL"
