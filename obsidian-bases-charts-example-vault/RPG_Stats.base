properties:
  note.Name:
    displayName: Name
  note.Class:
    displayName: Class
  note.Strength:
    displayName: Strength
  note.Intelligence:
    displayName: Intelligence
  note.Agility:
    displayName: Agility
views:
  - type: radar-chart
    name: Character Stats Radar
    filters:
      and:
        - note.Class != null
    xAxisProp: note.Name
    metricProps: note.Strength, note.Intelligence, note.Agility
    showLegend: true
