{
	"name": "obsidian-bases-charts",
	"version": "0.0.1",
	"description": "Advanced visualization for Obsidian via the Bases API.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build": "bun esbuild.config.mjs production",
		"dev": "bun esbuild.config.mjs",
		"lint": "eslint .",
		"test": "bun test ./tests",
		"test:coverage": "bun test ./tests --coverage --coverage-reporter=lcov",
		"test:e2e": "bun x playwright test",
		"test:e2e:headless": "xvfb-run --auto-servernum --server-args='-screen 0 1280x1024x24' bun x playwright test",
		"typecheck": "tsc --noEmit",
		"vault:dev": "bun scripts/vault-dev.ts",
		"vault:eval": "bun scripts/vault-eval.ts",
		"vault:install": "bun scripts/vault-install.ts",
		"vault:reload": "bun scripts/vault-reload.ts",
		"vault:screenshot": "bun scripts/vault-screenshot.ts"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/core": "^1.2.1",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^2.0.0",
		"@playwright/test": "^1.60.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.0",
		"commander": "^15.0.0",
		"esbuild": "0.28.1",
		"eslint": "^10",
		"eslint-plugin-functional": "^10.0.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-unicorn": "^68.0.0",
		"eslint-plugin-yml": "^3.4.0",
		"fast-check": "^4.8.0",
		"globals": "17.6.0",
		"jiti": "^2.7.0",
		"obsidian-launcher": "^3.0.4",
		"ts-node": "^10.9.2",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	},
	"dependencies": {
		"echarts": "6.1.0",
		"echarts-wordcloud": "^2.1.0",
		"i18next": "^26.3.1",
		"obsidian": "1.11.4",
		"remeda": "^2.37.0",
		"temporal-polyfill": "^1.0.1",
		"zod": "^4.4.3"
	}
}
